				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<allowedArchonexusCount>200</allowedArchonexusCount>
	</ThingDef>
	
	<ThingDef ParentName="PlantBase">
		<defName>Plant_BrewingEnhanced_Barley</defName>
		<label>barley plant</label>
		<description>Barley description.</description>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<Nutrition>0.31</Nutrition>
		</statBases>
		<graphicData>
			<texPath>things/plant/BarleyPlant</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>14</pathCost>
		<ingestible />
		<plant>
			<fertilityMin>0.70</fertilityMin>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestTag>Standard</harvestTag>
			<harvestedThingDef>BrewingEnhanced_RawBarley</harvestedThingDef>
			<harvestYield>16</harvestYield>
			<sowTags>
				<li>Ground</li>
			</sowTags>
			<topWindExposure>0.35</topWindExposure>
			<growDays>8.1</growDays>
			<immatureGraphicPath>things/plant/BarleyPlant_Immature</immatureGraphicPath>
			<visualSizeRange>0.5~1.4</visualSizeRange>
			<wildOrder>2</wildOrder>
			<purpose>Food</purpose>
			<humanFoodPlant>true</humanFoodPlant>
		</plant>
	</ThingDef>
	
