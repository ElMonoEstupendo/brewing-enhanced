<Defs>
	<StatCategoryDef>
		<defName>BrewingEnhanced_BeerStyleCategory</defName>
		<label>Beer Style</label>
		<displayOrder>10000</displayOrder>
	</StatCategoryDef>

	<ThingDef Name="BrewingEnhanced_Mash" ParentName="ResourceBase">
		<defName>BrewingEnhanced_Mash</defName>
		<label>mash</label>
		<description>A sweet liquid solution, composed of sugars from mashed grains steeped in water.</description>
		<graphicData>
		  <texPath>things/items/resource/mash</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<healthAffectsPrice>false</healthAffectsPrice>
		<rotatable>false</rotatable>
		<stackLimit>250</stackLimit>
		<thingCategories>
		  <li>Manufactured</li>
		</thingCategories>
		<statBases>
		  <DeteriorationRate>1.0</DeteriorationRate>
		  <MarketValue>2.5</MarketValue>
		  <Mass>0.8</Mass>
		  <Flammability>0.2</Flammability>
		  <MaxHitPoints>60</MaxHitPoints>
		</statBases>
		<tickerType>Rare</tickerType>
		<comps>
		  <li Class="CompProperties_Rottable">
			<daysToRotStart>5</daysToRotStart>
			<rotDestroys>true</rotDestroys>
		  </li>
		  <li Class="BrewingEnhanced.CompProperties_Blend">
			<ReductionFactor>4</ReductionFactor>
			<AcceptedDefs>
				<li>RawCorn</li>
				<li>RawRice</li>
				<li>BrewingEnhanced_RawBarley</li>
				<li>BrewingEnhanced_RawOats</li>
				<li>BrewingEnhanced_RawWheat</li>
				<li>BrewingEnhanced_RoastBarley</li>
			</AcceptedDefs>
		  </li>
		</comps>
	</ThingDef>
	
