<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="FermentingBarrel"]/comps</xpath>
		<value>
			<li Class="BrewingEnhanced.CompProperties_Blend">
				<IsFermenter>true</IsFermenter>
				<MaxDryHoppingProgress>0.5</MaxDryHoppingProgress>
				<DryHoppingTickCount>200</DryHoppingTickCount>
				<ReductionFactor>5</ReductionFactor>
				<AcceptedDefs>
					<li>RawCorn</li>
					<li>RawRice</li>
					<li>RawHops</li>
				</AcceptedDefs>
				<SecondaryItems>
					<RawBerries>25</RawBerries>
					<RawHops>25</RawHops>
					<RawAgave>25</RawAgave>
				</SecondaryItems>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="Beer"]/comps</xpath>
		<value>
			<li Class="BrewingEnhanced.CompProperties_Blend">
				<ReductionFactor>5</ReductionFactor>
				<AcceptedDefs>
					<li>RawCorn</li>
					<li>RawRice</li>
					<li>RawHops</li>
				</AcceptedDefs>
				<SecondaryItems>
					<RawBerries>25</RawBerries>
					<RawHops>25</RawHops>
					<RawAgave>25</RawAgave>
				</SecondaryItems>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="Wort"]/comps</xpath>
		<value>
			<li Class="BrewingEnhanced.CompProperties_Blend">
				<ReductionFactor>5</ReductionFactor>
				<AcceptedDefs>
					<li>RawCorn</li>
					<li>RawRice</li>
					<li>RawHops</li>
				</AcceptedDefs>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>RimCuisine 2 Core (Continued)</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAdd"> 
					<xpath>/Defs/ThingDef[defName="BrewingEnhanced_Mash"]/comps[@Class="CompProperties_Blend"]/acceptedDefs</xpath>
					<value>
						<li>RC2_RawOats</li>
						<li>RC2_RawBarley</li>
					</value>
				</li>
				<li Class="PatchOperationAdd"> 
					<xpath>/Defs/ThingDef[defName="Wort"]/comps[@Class="CompProperties_Blend"]/acceptedDefs</xpath>
					<value>
						<li>RC2_RawOats</li>
						<li>RC2_RawBarley</li>
					</value>
				</li>
				<li Class="PatchOperationAdd"> 
					<xpath>/Defs/ThingDef[defName="FermentingBarrel"]/comps[@Class="CompProperties_Blend"]/acceptedDefs</xpath>
					<value>
						<li>RC2_RawOats</li>
						<li>RC2_RawBarley</li>
					</value>
				</li>
				<li Class="PatchOperationAdd"> 
					<xpath>/Defs/ThingDef[defName="Beer"]/comps[@Class="CompProperties_Blend"]/acceptedDefs</xpath>
					<value>
						<li>RC2_RawOats</li>
						<li>RC2_RawBarley</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
	
	
</Patch>

